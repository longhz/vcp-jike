# JikeScraper Plugin - Configuration Template
# Copy this file to config.env and fill in your values

# ============================================================
# 基础配置
# ============================================================

# tokens.json 文件路径（存放登录态，默认保存在插件目录下）
# JikeTokensPath=/u01/VCPToolBox/Plugin/JikeScraper/tokens.json

# 即刻 API 基础地址（通常不需要修改）
# JikeApiBase=https://api.ruguoapp.com

# Web 端 Origin（通常不需要修改）
# JikeWebOrigin=https://web.okjike.com

# 默认返回条数上限
# JikeDefaultCount=25

# ============================================================
# 代理配置（可选）
# ============================================================

# HTTP 代理地址（如需要海外访问）
# 格式: http://user:password@host:port
# JikeProxyUrl=http://127.0.0.1:10808

# ============================================================
# 使用说明
# ============================================================
#
# 1. 首次使用前必须扫码登录:
#    cd /u01/VCPToolBox/Plugin/JikeScraper
#    node jike-setup.js
#
# 2. 登录成功后重启 vcp-main:
#    pm2 restart vcp-main
#
# 3. 验证插件加载:
#    pm2 logs vcp-main --lines 50 | grep JikeScraper
#
